<% content_for :header_title, "Dashboard" %>
<% content_for :title, "Admin Dashboard" %>

<div class="row g-4 mb-4">
  <!-- Posts Stat -->
  <div class="col-md-3">
    <div class="stat-card">
      <div class="stat-icon blue">
        <i class="bi bi-journal-text"></i>
      </div>
      <div class="stat-value"><%= @stats[:posts] %></div>
      <div class="stat-label">Total Posts</div>
      <div class="text-muted small mt-2">
        <i class="bi bi-check-circle text-success"></i> <%= @stats[:published_posts] %> published
      </div>
    </div>
  </div>
  
  <!-- Users Stat -->
  <div class="col-md-3">
    <div class="stat-card">
      <div class="stat-icon green">
        <i class="bi bi-people"></i>
      </div>
      <div class="stat-value"><%= @stats[:users] %></div>
      <div class="stat-label">Total Users</div>
      <div class="text-muted small mt-2">
        <i class="bi bi-person-plus"></i> <%= User.where('created_at >= ?', 7.days.ago).count %> this week
      </div>
    </div>
  </div>
  
  <!-- Comments Stat -->
  <div class="col-md-3">
    <div class="stat-card">
      <div class="stat-icon purple">
        <i class="bi bi-chat-left-text"></i>
      </div>
      <div class="stat-value"><%= @stats[:comments] %></div>
      <div class="stat-label">Total Comments</div>
      <div class="text-muted small mt-2">
        <i class="bi bi-chat"></i> <%= Comment.where('created_at >= ?', 7.days.ago).count %> this week
      </div>
    </div>
  </div>
  
  <!-- Quick Actions -->
  <div class="col-md-3">
    <div class="stat-card">
      <div class="stat-icon orange">
        <i class="bi bi-lightning"></i>
      </div>
      <div class="stat-label mb-2">Quick Actions</div>
      <div class="d-grid gap-2">
        <%= link_to new_post_path, class: "btn btn-sm btn-outline-primary" do %>
          <i class="bi bi-plus"></i> New Post
        <% end %>
        <%= link_to admin_users_path, class: "btn btn-sm btn-outline-secondary" do %>
          <i class="bi bi-people"></i> Manage Users
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <!-- Recent Posts -->
  <div class="col-md-6">
    <div class="admin-table">
      <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-journal-text"></i> Recent Posts</h6>
        <%= link_to "View All", admin_posts_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% @stats[:recent_posts].each do |post| %>
            <tr>
              <td>
                <%= link_to truncate(post.title, length: 40), admin_post_path(post), class: "text-decoration-none" %>
              </td>
              <td><%= post.user.username %></td>
              <td>
                <% if post.published? %>
                  <span class="badge badge-soft-success">Published</span>
                <% else %>
                  <span class="badge badge-soft-warning">Draft</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  
  <!-- Recent Users -->
  <div class="col-md-6">
    <div class="admin-table">
      <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-people"></i> Recent Users</h6>
        <%= link_to "View All", admin_users_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>User</th>
            <th>Email</th>
            <th>Joined</th>
          </tr>
        </thead>
        <tbody>
          <% @stats[:recent_users].each do |user| %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <% if user.has_avatar? %>
                    <%= image_tag url_for(user.avatar), class: "rounded-circle", width: 32, height: 32 %>
                  <% else %>
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.75rem;">
                      <%= user.username.first.upcase %>
                    </div>
                  <% end %>
                  <%= link_to user.username, admin_user_path(user), class: "text-decoration-none" %>
                </div>
              </td>
              <td class="text-muted small"><%= user.email %></td>
              <td class="text-muted small"><%= time_ago_in_words(user.created_at) %> ago</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  
  <!-- Recent Comments -->
  <div class="col-12">
    <div class="admin-table">
      <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-chat-left-text"></i> Recent Comments</h6>
        <%= link_to "View All", admin_comments_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>Comment</th>
            <th>Author</th>
            <th>On</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% @stats[:recent_comments].each do |comment| %>
            <tr>
              <td><%= truncate(comment.body, length: 60) %></td>
              <td><%= link_to comment.user.username, admin_user_path(comment.user) %></td>
              <td>
                <% if comment.commentable.is_a?(Post) %>
                  <%= link_to truncate(comment.commentable.title, length: 30), admin_post_path(comment.commentable) %>
                <% else %>
                  <span class="text-muted">Reply</span>
                <% end %>
              </td>
              <td class="text-muted small"><%= time_ago_in_words(comment.created_at) %> ago</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
