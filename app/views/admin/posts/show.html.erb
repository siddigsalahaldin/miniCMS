<% content_for :header_title, "Post Details" %>
<% content_for :title, @post.title %>

<div class="row">
  <div class="col-lg-8">
    <div class="admin-table p-4">
      <div class="mb-4">
        <h4><%= @post.title %></h4>
        <div class="text-muted small">
          <i class="bi bi-person"></i> <%= link_to @post.user.username, admin_user_path(@post.user) %> &bull;
          <i class="bi bi-clock"></i> <%= time_ago_in_words(@post.created_at) %> ago
        </div>
      </div>
      
      <div class="mb-4">
        <strong>Status:</strong>
        <% if @post.published? %>
          <span class="badge badge-soft-success ms-2">Published</span>
        <% else %>
          <span class="badge badge-soft-warning ms-2">Draft</span>
        <% end %>
      </div>
      
      <div class="mb-4">
        <strong>Content:</strong>
        <div class="mt-2 trix-content">
          <%= @post.body %>
        </div>
      </div>
      
      <div class="d-flex gap-2">
        <%= link_to "Edit Post", edit_post_path(@post), class: "btn btn-primary" %>
        <% if @post.published? %>
          <%= button_to "Unpublish", unpublish_admin_post_path(@post), method: :patch, class: "btn btn-warning" %>
        <% else %>
          <%= button_to "Publish", publish_admin_post_path(@post), method: :patch, class: "btn btn-success" %>
        <% end %>
        <%= link_to "View on Site", post_path(@post), class: "btn btn-outline-secondary", target: "_blank" %>
      </div>
    </div>
  </div>
  
  <div class="col-lg-4">
    <div class="admin-table p-4 mb-4">
      <h6 class="mb-3">Post Info</h6>
      <ul class="list-unstyled mb-0">
        <li class="mb-2"><strong>Slug:</strong> <%= @post.slug %></li>
        <li class="mb-2"><strong>Created:</strong> <%= @post.created_at.strftime("%B %d, %Y") %></li>
        <li class="mb-2"><strong>Updated:</strong> <%= time_ago_in_words(@post.updated_at) %> ago</li>
      </ul>
    </div>
    
    <div class="admin-table p-4">
      <h6 class="mb-3">Comments (<%= @post.comments.count %>)</h6>
      <% if @post.comments.any? %>
        <div class="list-group list-group-flush">
          <% @post.comments.recent.limit(5).each do |comment| %>
            <div class="list-group-item px-0">
              <small class="text-muted"><%= comment.user.username %></small>
              <p class="mb-1 small"><%= truncate(comment.body, length: 50) %></p>
              <%= link_to "View", admin_comment_path(comment), class: "small" %>
            </div>
          <% end %>
        </div>
        <%= link_to "View All Comments", admin_comments_path(q: { commentable_id_eq: @post.id }), class: "btn btn-sm btn-outline-primary mt-3" %>
      <% else %>
        <p class="text-muted small mb-0">No comments yet.</p>
      <% end %>
    </div>
  </div>
</div>

<%= button_to "Delete Post", admin_post_path(@post), method: :delete, class: "btn btn-danger mt-4", form: { data: { turbo_confirm: "Are you sure you want to delete this post?" } } %>
