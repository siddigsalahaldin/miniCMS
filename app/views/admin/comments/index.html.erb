<% content_for :header_title, "Comments" %>
<% content_for :title, "Manage Comments" %>

<div class="admin-table">
  <table class="table table-hover mb-0">
    <thead>
      <tr>
        <th>Comment</th>
        <th>Author</th>
        <th>On</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @comments.each do |comment| %>
        <tr>
          <td style="max-width: 400px;">
            <%= truncate(comment.body, length: 80) %>
          </td>
          <td><%= link_to comment.user.username, admin_user_path(comment.user) %></td>
          <td>
            <% if comment.commentable.is_a?(Post) %>
              <%= link_to truncate(comment.commentable.title, length: 30), admin_post_path(comment.commentable) %>
            <% else %>
              <span class="text-muted">Reply to comment</span>
            <% end %>
          </td>
          <td class="text-muted small"><%= time_ago_in_words(comment.created_at) %> ago</td>
          <td>
            <div class="btn-group btn-group-sm" role="group">
              <%= link_to "View", admin_comment_path(comment), class: "btn btn-outline-secondary" %>
              <%= button_to "Delete", admin_comment_path(comment), method: :delete, class: "btn btn-outline-danger", form: { data: { turbo_confirm: "Are you sure?" } } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
