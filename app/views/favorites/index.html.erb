<% content_for :title, t("nav.favorites") %>

<div class="row">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0"><i class="bi bi-star-fill text-warning"></i> <%= t("nav.favorites") %></h1>
      <%= link_to root_path, class: "btn btn-outline-secondary" do %>
        <i class="bi bi-arrow-left"></i> <%= t("common.back_to_posts") %>
      <% end %>
    </div>

    <% if @posts.any? %>
      <div class="row g-4">
        <% @posts.each do |post| %>
          <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
              <div class="card-body">
                <h2 class="h5 card-title mb-2">
                  <%= link_to post.title, post, class: "text-decoration-none text-dark stretched-link" %>
                </h2>
                <p class="card-text text-muted small">
                  <i class="bi bi-person"></i> <%= link_to post.user.username, user_path(post.user), class: "text-decoration-none" %>
                  <span class="ms-2"><i class="bi bi-clock"></i> <%= time_ago_in_words_locale(post.created_at) %></span>
                </p>
                <p class="card-text"><%= truncate(post.body.to_plain_text, length: 150) %></p>
              </div>
              <div class="card-footer bg-white border-0">
                <%= button_to unfavorite_post_path(post), method: :delete, class: "btn btn-outline-warning btn-sm" do %>
                  <i class="bi bi-star-fill"></i> <%= t("common.unfavorite") %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-star display-1 text-warning"></i>
        <h3 class="mt-3"><%= t("common.no_favorites") %></h3>
        <p class="text-muted"><%= t("common.start_exploring") %></p>
        <%= link_to t("common.browse_posts"), root_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
