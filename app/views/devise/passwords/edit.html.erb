<% content_for :title, "Reset Password" %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-5">
        <div class="text-center mb-4">
          <i class="bi bi-lock display-4 text-primary mb-3"></i>
          <h1 class="h3 mb-2">Reset Password</h1>
          <p class="text-muted">Enter your new password below</p>
        </div>

        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>
          <%= f.hidden_field :reset_password_token %>

          <div class="mb-3">
            <%= f.label :password, "New Password", class: "form-label" %>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock"></i></span>
              <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-control", placeholder: "New password" %>
            </div>
            <% if @minimum_password_length %>
              <div class="form-text">Minimum <%= @minimum_password_length %> characters</div>
            <% end %>
          </div>

          <div class="mb-4">
            <%= f.label :password_confirmation, "Confirm New Password", class: "form-label" %>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "Confirm new password" %>
            </div>
          </div>

          <%= f.submit "Reset Password", class: "btn btn-primary btn-lg w-100 mb-3" %>
        <% end %>

        <div class="text-center">
          <%= link_to "Back to sign in", new_session_path(resource_name), class: "text-decoration-none" %>
        </div>
      </div>
    </div>
  </div>
</div>
