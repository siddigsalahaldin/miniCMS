<% content_for :title, @user.username %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body text-center p-5">
        <% if @user.has_avatar? %>
          <%= image_tag url_for(@user.avatar), alt: @user.username, class: "rounded-circle mb-3 shadow", width: 120, height: 120 %>
        <% else %>
          <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow" style="width: 120px; height: 120px; font-size: 3rem;">
            <%= @user.username.first.upcase %>
          </div>
        <% end %>

        <h1 class="h2 mb-2"><%= @user.username %></h1>

        <% if @user.bio.present? %>
          <p class="text-muted mb-3"><%= @user.bio %></p>
        <% end %>

        <div class="d-flex justify-content-center gap-4 mb-3">
          <div class="text-center">
            <div class="h4 mb-0"><strong><%= @user.posts.count %></strong></div>
            <small class="text-muted"><i class="bi bi-file-text"></i> <%= t("common.posts") %></small>
          </div>
          <div class="text-center">
            <div class="h4 mb-0"><strong><%= @user.followers.count %></strong></div>
            <small class="text-muted"><i class="bi bi-people"></i> <%= t("common.followers") %></small>
          </div>
          <div class="text-center">
            <div class="h4 mb-0"><strong><%= @user.followings.count %></strong></div>
            <small class="text-muted"><i class="bi bi-person-check"></i> <%= t("common.following") %></small>
          </div>
        </div>

        <div class="d-flex justify-content-center gap-2">
          <% if current_user && current_user != @user %>
            <%= render partial: "shared/follow_button", locals: { user: @user } %>
          <% end %>
          <% if current_user == @user %>
            <%= link_to edit_user_registration_path, class: "btn btn-outline-primary" do %>
              <i class="bi bi-gear"></i> <%= t("common.edit_profile") %>
            <% end %>
          <% end %>
          <%= link_to user_followers_path(@user), class: "btn btn-outline-secondary" do %>
            <i class="bi bi-people"></i> <%= t("common.followers") %>
          <% end %>
          <%= link_to user_followings_path(@user), class: "btn btn-outline-secondary" do %>
            <i class="bi bi-person-check"></i> <%= t("common.following") %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white">
        <h4 class="mb-0"><i class="bi bi-journal-text"></i> <%= t("common.posts") %> <%= t("common.by") %> <%= @user.username %></h4>
      </div>
      <div class="card-body">
        <% if @user.posts.published.any? %>
          <div class="list-group list-group-flush">
            <% @user.posts.published.recent.limit(10).each do |post| %>
              <div class="list-group-item px-0">
                <div class="d-flex w-100 justify-content-between align-items-start">
                  <div class="flex-grow-1">
                    <h5 class="mb-1">
                      <%= link_to post.title, post, class: "text-decoration-none text-dark" %>
                    </h5>
                    <small class="text-muted">
                      <i class="bi bi-clock"></i> <%= time_ago_in_words_locale(post.created_at) %>
                    </small>
                    <p class="mt-2 mb-0 text-muted"><%= truncate(post.body.to_plain_text, length: 100) %></p>
                  </div>
                  <div class="ms-3">
                    <span class="badge bg-light text-dark">
                      <i class="bi bi-heart"></i> <%= post.reactions.count %>
                    </span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-4">
            <i class="bi bi-journal-x display-4 text-muted"></i>
            <p class="mt-3 text-muted"><%= t("common.no_posts") %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
