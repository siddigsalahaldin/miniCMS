<footer class="main-footer">
  <div class="container">
    <!-- Footer Top Section -->
    <div class="footer-top py-5">
      <div class="row g-4">
        <!-- Brand Column -->
        <div class="col-lg-4 col-md-6">
          <div class="footer-brand mb-3">
            <i class="bi bi-layers-half me-2"></i>
            <span class="brand-text">mini<span class="brand-highlight">CMS</span></span>
          </div>
          <p class="text-muted mb-3">
            <%= t("tagline") %>
            <%= t("subtitle") %>
          </p>
          <div class="social-links">
            <a href="#" class="social-link" title="GitHub"><i class="bi bi-github"></i></a>
            <a href="#" class="social-link" title="Twitter"><i class="bi bi-twitter"></i></a>
            <a href="#" class="social-link" title="LinkedIn"><i class="bi bi-linkedin"></i></a>
            <a href="#" class="social-link" title="RSS Feed"><i class="bi bi-rss"></i></a>
          </div>
        </div>

        <!-- Quick Links Column -->
        <div class="col-lg-2 col-md-6">
          <h5 class="footer-title"><%= t("footer.quick_links") %></h5>
          <ul class="footer-links list-unstyled">
            <li><a href="<%= root_path %>"><i class="bi bi-chevron-right"></i> <%= t("nav.home") %></a></li>
            <li><a href="<%= posts_path %>"><i class="bi bi-chevron-right"></i> <%= t("nav.posts") %></a></li>
            <li><a href="<%= new_user_registration_path %>"><i class="bi bi-chevron-right"></i> <%= t("nav.sign_up") %></a></li>
            <li><a href="<%= new_user_session_path %>"><i class="bi bi-chevron-right"></i> <%= t("nav.sign_in") %></a></li>
          </ul>
        </div>

        <!-- Resources Column -->
        <div class="col-lg-3 col-md-6">
          <h5 class="footer-title"><%= t("footer.resources") %></h5>
          <ul class="footer-links list-unstyled">
            <li><a href="#"><i class="bi bi-chevron-right"></i> <%= t("footer.documentation") %></a></li>
            <li><a href="#"><i class="bi bi-chevron-right"></i> <%= t("footer.api_reference") %></a></li>
            <li><a href="#"><i class="bi bi-chevron-right"></i> <%= t("footer.support") %></a></li>
            <li><a href="#"><i class="bi bi-chevron-right"></i> <%= t("footer.privacy_policy") %></a></li>
          </ul>
        </div>

        <!-- Contact Column -->
        <div class="col-lg-3 col-md-6">
          <h5 class="footer-title"><%= t("footer.get_in_touch") %></h5>
          <ul class="footer-contact list-unstyled text-muted">
            <li class="mb-2">
              <i class="bi bi-envelope me-2"></i>
              <a href="mailto:<%= t("footer.email") %>" class="text-reset text-decoration-none"><%= t("footer.email") %></a>
            </li>
            <li class="mb-2">
              <i class="bi bi-geo-alt me-2"></i>
              <span><%= t("footer.location") %></span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Footer Bottom Section -->
    <div class="footer-bottom py-3 border-top">
      <div class="row align-items-center">
        <div class="col-md-6 text-center text-md-start">
          <p class="mb-0 text-muted">
            &copy; <%= Date.today.year %> miniCMS. <%= t("footer.copyright") %>
          </p>
        </div>
        <div class="col-md-6 text-center text-md-end">
          <p class="mb-0 text-muted small">
            <%= t("footer.built_with") %> <i class="bi bi-heart-fill text-danger"></i> <%= t("footer.using") %> Ruby on Rails
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>
