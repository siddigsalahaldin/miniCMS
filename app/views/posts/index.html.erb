<% content_for :title, t("posts.latest") %>

<div class="row">
  <div class="col-lg-8">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0"><i class="bi bi-journal-text"></i> <%= t("posts.latest") %></h1>
      <% if current_user %>
        <%= link_to new_post_path, class: "btn btn-primary" do %>
          <i class="bi bi-plus-lg"></i> <%= t("nav.new_post") %>
        <% end %>
      <% end %>
    </div>

    <% if @posts.any? %>
      <div class="row g-4">
        <% @posts.each do |post| %>
          <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
              <div class="card-body">
                <h2 class="h5 card-title mb-2">
                  <%= link_to post.title, post, class: "text-decoration-none text-dark stretched-link" %>
                </h2>
                <p class="card-text text-muted small">
                  <i class="bi bi-person"></i> <%= link_to post.user.username, user_path(post.user), class: "text-decoration-none" %>
                  <span class="ms-2"><i class="bi bi-clock"></i> <%= time_ago_in_words_locale(post.created_at) %></span>
                </p>
                <p class="card-text"><%= truncate(post.body.to_plain_text, length: 150) %></p>
              </div>
              <div class="card-footer bg-white border-0">
                <small class="text-muted">
                  <i class="bi bi-chat-left"></i> <%= t("posts.comments_count", count: post.comments.count) %>
                  <span class="ms-2"><i class="bi bi-heart"></i> <%= t("posts.reactions_count", count: post.reactions.count) %></span>
                </small>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-journal-x display-1 text-muted"></i>
        <h3 class="mt-3"><%= t("posts.no_posts_yet") %></h3>
        <p class="text-muted"><%= t("posts.be_first") %></p>
        <%= link_to t("posts.create_post"), new_post_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>

  <div class="col-lg-4">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white">
        <h5 class="mb-0"><i class="bi bi-star-fill text-warning"></i> <%= t("posts.featured") %></h5>
      </div>
      <div class="card-body">
        <% if @featured_posts&.any? %>
          <ul class="list-unstyled mb-0">
            <% @featured_posts.each do |post| %>
              <li class="mb-2">
                <%= link_to post.title, post, class: "text-decoration-none" %>
                <small class="text-muted d-block"><%= time_ago_in_words_locale(post.created_at) %></small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0"><%= t("posts.no_featured_posts") %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>
