# Railway Setup Script
# Run this after deploying to Railway for the first time

#!/usr/bin/env bash

set -e

echo "🚂 Railway Setup for miniCMS"
echo "=============================="
echo ""

# Check if Railway CLI is installed
if ! command -v railway &> /dev/null; then
    echo "❌ Railway CLI not found. Install with: npm install -g @railway/cli"
    exit 1
fi

# Check if logged in
if ! railway whoami &> /dev/null; then
    echo "🔐 Logging in to Railway..."
    railway login
fi

echo "✅ Logged in as $(railway whoami)"
echo ""

# Initialize project if needed
if [ ! -f ".railway/config.json" ]; then
    echo "📦 Initializing Railway project..."
    railway init
fi

# Check for PostgreSQL
echo "🔍 Checking for PostgreSQL service..."
if ! railway variables get DATABASE_URL &> /dev/null; then
    echo "📊 Adding PostgreSQL database..."
    railway add postgresql
fi

echo "✅ PostgreSQL configured"
echo ""

# Generate secret key base if not exists
if [ -z "$SECRET_KEY_BASE" ]; then
    echo "🔑 Generating SECRET_KEY_BASE..."
    SECRET_KEY_BASE=$(openssl rand -hex 64)
    railway variables set SECRET_KEY_BASE="$SECRET_KEY_BASE"
fi

# Get RAILS_MASTER_KEY from config/master.key
if [ -f "config/master.key" ]; then
    echo "🔐 Setting RAILS_MASTER_KEY..."
    RAILS_MASTER_KEY=$(cat config/master.key)
    railway variables set RAILS_MASTER_KEY="$RAILS_MASTER_KEY"
else
    echo "⚠️  config/master.key not found. Please set RAILS_MASTER_KEY manually:"
    echo "   railway variables set RAILS_MASTER_KEY=<your-key>"
fi

# Set production environment
echo "⚙️  Setting production environment variables..."
railway variables set RAILS_ENV=production
railway variables set RAILS_LOG_LEVEL=info
railway variables set RAILS_MAX_THREADS=5

echo ""
echo "✅ Setup complete!"
echo ""
echo "📋 Next steps:"
echo "   1. Deploy: railway up"
echo "   2. Migrate: railway run bin/rails db:migrate"
echo "   3. Create admin: railway run bin/rails runner \"User.create!(email: 'admin@example.com', password: 'password', password_confirmation: 'password', admin: true)\""
echo "   4. Open app: railway open"
echo ""
